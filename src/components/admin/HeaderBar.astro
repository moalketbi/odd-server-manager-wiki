---
interface Props {
  username: string;
  healthy: boolean;
}
const { username, healthy } = Astro.props;
---

<header class="header-bar">
  <div class="brand">
    <span class="brand-icon">⚙️</span>
    <span class="brand-text">Wiki Admin</span>
  </div>
  <div class="user">
    <span class={`dot ${healthy ? 'dot--ok' : 'dot--err'}`} title={healthy ? 'Token healthy' : 'Token problem'}></span>
    <span class="login">@{username}</span>
    <button id="logout-btn" type="button">Logout</button>
  </div>
</header>

<style>
  .header-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 1rem; background: var(--surface);
    border: 1px solid var(--border); border-radius: 10px; margin-bottom: 1rem;
  }
  .brand { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; }
  .brand-icon { font-size: 1.1rem; }
  .user { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; }
  .login { color: var(--muted); }
  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .dot--ok { background: #2ecc71; box-shadow: 0 0 6px rgba(46,204,113,0.6); }
  .dot--err { background: #e74c3c; }
  #logout-btn {
    background: transparent; color: var(--accent-high);
    border: 1px solid var(--border); padding: 0.3rem 0.7rem;
    border-radius: 5px; font-size: 0.85rem; cursor: pointer;
  }
  #logout-btn:hover { background: var(--raised); }
</style>
