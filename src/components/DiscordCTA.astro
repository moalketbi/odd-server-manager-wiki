---
interface Props {
  invite?: string;
  title?: string;
  body?: string;
  cta?: string;
}
const {
  invite = 'https://discord.gg/PLACEHOLDER_INVITE',
  title = 'Still stuck?',
  body = 'Ask the community on Discord — usually answered in minutes.',
  cta = 'Join',
} = Astro.props;
---

<a class="discord-cta" href={invite} target="_blank" rel="noopener">
  <span class="discord-cta__icon">💬</span>
  <span class="discord-cta__text">
    <span class="discord-cta__title">{title}</span>
    <span class="discord-cta__body">{body}</span>
  </span>
  <span class="discord-cta__btn">{cta}</span>
</a>

<style>
  .discord-cta {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    background: linear-gradient(135deg, rgba(88,101,242,0.18) 0%, rgba(64,78,237,0.08) 100%);
    border: 1px solid rgba(88,101,242,0.4);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    margin: 2rem 0 1rem;
    text-decoration: none;
    color: inherit;
    transition: transform 120ms ease;
  }
  .discord-cta:hover { transform: translateY(-1px); }
  .discord-cta__icon {
    width: 38px; height: 38px; border-radius: 50%;
    background: #5865F2; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; flex-shrink: 0;
  }
  .discord-cta__text { flex: 1; display: flex; flex-direction: column; }
  .discord-cta__title { color: var(--sl-color-white); font-weight: 700; font-size: 0.95rem; }
  .discord-cta__body { color: var(--sl-color-gray-2); font-size: 0.82rem; }
  .discord-cta__btn {
    background: #5865F2; color: #fff; font-weight: 700;
    font-size: 0.82rem; padding: 0.4rem 0.9rem; border-radius: 6px;
  }
</style>
