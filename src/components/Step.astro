---
interface Props {
  n: number;
  title: string;
}
const { n, title } = Astro.props;
---

<div class="step-card">
  <div class="step-num">{n}</div>
  <div class="step-title">{title}</div>
  <div class="step-body"><slot /></div>
</div>

<style>
  .step-card {
    position: relative;
    background: var(--sl-color-gray-7);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 10px;
    padding: 1.25rem 1.25rem 1rem;
    margin: 1.75rem 0 1rem;
  }
  .step-num {
    position: absolute;
    top: -12px;
    inset-inline-start: 1.25rem;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--sl-color-accent);
    color: #0B0C10;
    font-weight: 800;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 14px -4px rgba(199, 106, 42, 0.6);
  }
  .step-title {
    color: var(--sl-color-white);
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
  }
  .step-body :global(p) { margin: 0.4rem 0; }
</style>
